package com.surprisekhoza.sktunnel

import android.os.Bundle
import android.widget.ArrayAdapter
import android.widget.Spinner
import android.widget.TextView
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import com.google.android.material.button.MaterialButton

class MainActivity : AppCompatActivity() {

    private var connected = false

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        setContentView(R.layout.activity_main)

        val protocols = arrayOf(
            "VMESS",
            "VLESS",
            "TROJAN",
            "SHADOWSOCKS",
            "SOCKS",
            "HTTP",
            "SSH",
            "WIREGUARD",
            "HYSTERIA",
            "HYSTERIA2",
            "TUIC",
            "SHADOWTLS",
            "ANYTLS",
            "NAIVE",
            "DIRECT",
            "BLOCK",
            "DNS",
            "TOR",
            "REALITY",
            "BROOK",
            "MIERU",
            "WS",
            "HTTPUPGRADE",
            "GRPC",
            "QUIC",
            "TCP",
            "KCP",
            "UDP",
            "TUN",
            "MIXED",
            "REDIRECT",
            "TPROXY"
        )

        val spinner = findViewById<Spinner>(R.id.protocolSpinner)

        val statusText = findViewById<TextView>(R.id.statusText)

        val connectBtn = findViewById<MaterialButton>(R.id.connectBtn)

        spinner.adapter = ArrayAdapter(
            this,
            android.R.layout.simple_spinner_dropdown_item,
            protocols
        )

        connectBtn.setOnClickListener {

            connected = !connected

            val selected = spinner.selectedItem.toString()

            if (connected) {

                statusText.text = "Connected"
                statusText.setTextColor(getColor(R.color.connected))

                connectBtn.text = "DISCONNECT"

                Toast.makeText(
                    this,
                    "Connected using $selected",
                    Toast.LENGTH_SHORT
                ).show()

            } else {

                statusText.text = "Disconnected"
                statusText.setTextColor(getColor(R.color.disconnected))

                connectBtn.text = "CONNECT"

                Toast.makeText(
                    this,
                    "VPN Disconnected",
                    Toast.LENGTH_SHORT
                ).show()
            }
        }
    }
}