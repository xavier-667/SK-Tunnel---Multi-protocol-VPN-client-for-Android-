package com.surprisekhoza.sktunnel

import android.app.Activity
import android.content.Intent
import android.net.VpnService
import android.os.Bundle
import android.widget.ArrayAdapter
import android.widget.Spinner
import android.widget.TextView
import android.widget.Toast
import androidx.activity.result.contract.ActivityResultContracts
import androidx.appcompat.app.AppCompatActivity
import com.google.android.material.button.MaterialButton

class MainActivity : AppCompatActivity() {

    private var connected = false

    private lateinit var statusText: TextView
    private lateinit var connectBtn: MaterialButton
    private lateinit var spinner: Spinner

    private val vpnPermission =
        registerForActivityResult(ActivityResultContracts.StartActivityForResult()) { result ->
            if (result.resultCode == Activity.RESULT_OK) {
                startVpn()
            } else {
                Toast.makeText(this, "VPN permission denied", Toast.LENGTH_SHORT).show()
            }
        }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        val protocols = arrayOf(
            "VMESS","VLESS","TROJAN","SHADOWSOCKS","SOCKS","HTTP","SSH",
            "WIREGUARD","HYSTERIA","TUIC","SHADOWTLS","ANYTLS","NAIVE",
            "DIRECT","BLOCK","DNS","TOR","REALITY","BROOK","MIERU",
            "WS","GRPC","QUIC","TCP","UDP","TUN","MIXED","TPROXY"
        )

        spinner = findViewById(R.id.protocolSpinner)
        statusText = findViewById(R.id.statusText)
        connectBtn = findViewById(R.id.connectBtn)

        spinner.adapter = ArrayAdapter(
            this,
            android.R.layout.simple_spinner_dropdown_item,
            protocols
        )

        connectBtn.setOnClickListener {
            if (!connected) {
                requestVpnPermission()
            } else {
                stopVpn()
            }
        }
    }

    private fun requestVpnPermission() {
        val intent = VpnService.prepare(this)
        if (intent != null) {
            vpnPermission.launch(intent)
        } else {
            startVpn()
        }
    }

    private fun startVpn() {
        connected = true

        statusText.text = "Connected"
        connectBtn.text = "DISCONNECT"

        Toast.makeText(this, "VPN Started (ready for sing-box)", Toast.LENGTH_SHORT).show()

        // NEXT STEP: start sing-box service here
        val intent = Intent(this, SktunnelVpnService::class.java)
        startService(intent)
    }

    private fun stopVpn() {
        connected = false

        statusText.text = "Disconnected"
        connectBtn.text = "CONNECT"

        Toast.makeText(this, "VPN Stopped", Toast.LENGTH_SHORT).show()

        val intent = Intent(this, SktunnelVpnService::class.java)
        stopService(intent)
    }
}