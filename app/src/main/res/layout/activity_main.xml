<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050B07"
    android:padding="20dp">

    <!-- APP TITLE -->

    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SK Tunnel"
        android:textColor="#39FF88"
        android:textStyle="bold"
        android:textSize="30sp"
        android:layout_marginTop="20dp"/>

    <!-- STATUS CARD -->

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#0B1510"
        app:strokeColor="#39FF88"
        app:strokeWidth="1dp"
        app:cardCornerRadius="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VPN STATUS"
                android:textColor="#8FA99A"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disconnected"
                android:textColor="#FF5252"
                android:textStyle="bold"
                android:textSize="26sp"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- PROTOCOL CARD -->

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#0B1510"
        app:strokeColor="#39FF88"
        app:strokeWidth="1dp"
        app:cardCornerRadius="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT PROTOCOL"
                android:textColor="#8FA99A"
                android:textSize="12sp"/>

            <Spinner
                android:id="@+id/protocolSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#39FF88"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- CONNECT BUTTON -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/connectBtn"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:layout_marginTop="34dp"
        android:text="CONNECT"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#000000"
        android:background="@drawable/bg_button"/>

</LinearLayout>